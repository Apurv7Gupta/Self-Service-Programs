javascript:(function(){if(document.getElementById('yt-speed-dom'))return;const css=`#yt-speed-dom{position:fixed;top:70px;left:20px;z-index:2147483647;background:rgba(5,15,30,0.75);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border:1px solid rgba(0,170,255,0.3);color:#fff;padding:12px;border-radius:16px;font-family:'Segoe UI',Roboto,sans-serif;width:240px;min-width:140px;min-height:140px;box-shadow:0 8px 32px rgba(0,0,0,0.4),inset 0 0 15px rgba(0,170,255,0.1);display:flex;flex-direction:column;gap:10px;user-select:none;transition:border 0.3s}#yt-speed-dom:hover{border:1px solid rgba(0,170,255,0.6)}#yt-speed-dom .btn-grid{display:flex;flex-wrap:wrap;gap:6px;flex:1;align-content:flex-start;overflow:hidden}#yt-speed-dom button{background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);color:#e0f2ff;padding:0;height:32px;border-radius:8px;cursor:pointer;font-weight:600;transition:all 0.2s cubic-bezier(0.4,0,0.2,1);flex:1 0 34px;font-size:12px;display:flex;align-items:center;justify-content:center}#yt-speed-dom button:hover{background:rgba(0,170,255,0.2);border-color:#00aaff;color:#fff;transform:translateY(-1px);box-shadow:0 4px 12px rgba(0,170,255,0.3)}#yt-speed-dom button.tiny-overflow{flex:0 0 15px !important;min-width:15px !important;padding:0;font-size:10px;background:transparent;color:rgba(255,255,255,0.3);cursor:default;border:none}#yt-speed-dom input{background:rgba(0,0,0,0.4);border:1px solid rgba(0,170,255,0.2);color:#00ccff;padding:8px;border-radius:8px;width:100%;text-align:center;font-family:'Cascadia Code',monospace;box-sizing:border-box;outline:none;transition:all 0.3s}#yt-speed-dom input:focus{border-color:#00aaff;box-shadow:0 0 8px rgba(0,170,255,0.4)}%60;const style=document.createElement('style');style.appendChild(document.createTextNode(css));document.head.appendChild(style);const panel=document.createElement('div');panel.id='yt-speed-dom';const title=document.createElement('div');title.textContent='speed control';title.style.cssText='color:rgba(0,170,255,0.8);font-size:10px;letter-spacing:1px;font-weight:800;display:flex;justify-content:space-between;cursor:grab;padding:2px 4px;text-transform:uppercase';const closeBtn=document.createElement('span');closeBtn.textContent='×';closeBtn.style.cssText='cursor:pointer;font-size:18px;line-height:12px;color:rgba(255,255,255,0.5)';closeBtn.onclick=()=>panel.remove();title.appendChild(closeBtn);panel.appendChild(title);const btnContainer=document.createElement('div');btnContainer.className='btn-grid';panel.appendChild(btnContainer);const inputRow=document.createElement('div');const input=document.createElement('input');input.type='number';input.step='0.1';input.min='0.1';input.max='16';input.value='1';input.oninput=(e)=>setSpeed(Number(e.target.value));inputRow.appendChild(input);panel.appendChild(inputRow);document.body.appendChild(panel);const toast=document.createElement('div');toast.textContent='Loaded';toast.style.cssText='position:fixed;top:20px;left:50%;transform:translateX(-50%);background:rgba(0,170,255,0.9);backdrop-filter:blur(4px);color:white;padding:10px 24px;border-radius:50px;z-index:2147483647;font-family:sans-serif;font-size:12px;letter-spacing:1px;font-weight:bold;pointer-events:none;box-shadow:0 4px 20px rgba(0,170,255,0.4);animation:toastFade 2s forwards;';document.body.appendChild(toast);const sAnim=document.createElement('style');sAnim.textContent='@keyframes toastFade{0%{opacity:0;transform:translateX(-50%) translateY(-20px)}20%{opacity:1;transform:translateX(-50%) translateY(0)}80%{opacity:1}100%{opacity:0}}';document.head.appendChild(sAnim);setTimeout(()=>toast.remove(),2000);const MARGIN=10;let state={r:false,d:false,dir:'',x:0,y:0,w:0,h:0,l:0,t:0};panel.onmousemove=(e)=>{if(state.r||state.d)return;const r=panel.getBoundingClientRect();const x=e.clientX-r.left,y=e.clientY-r.top,w=r.width,h=r.height;let d='';if(y<MARGIN)d+='n';else if(y>h-MARGIN)d+='s';if(x<MARGIN)d+='w';else if(x>w-MARGIN)d+='e';panel.style.cursor=d?d+'-resize':'default';title.style.cursor=d?'inherit':'grab'};panel.onmousedown=(e)=>{const r=panel.getBoundingClientRect();const d=panel.style.cursor;if(d.includes('resize')){state={r:true,dir:d.replace('-resize',''),x:e.clientX,y:e.clientY,w:r.width,h:r.height,l:r.left,t:r.top};e.preventDefault();e.stopPropagation()}else if(e.target===title||e.target.parentNode===title){state={d:true,x:e.clientX,y:e.clientY,l:r.left,t:r.top};title.style.cursor='grabbing';e.preventDefault()}};const mv=(e)=>{if(state.d){panel.style.left=(state.l+(e.clientX-state.x))+'px';panel.style.top=(state.t+(e.clientY-state.y))+'px'}else if(state.r){const dx=e.clientX-state.x,dy=e.clientY-state.y;if(state.dir.includes('e'))panel.style.width=Math.max(140,state.w+dx)+'px';if(state.dir.includes('s'))panel.style.height=Math.max(140,state.h+dy)+'px';if(state.dir.includes('w')){const nw=Math.max(140,state.w-dx);panel.style.width=nw+'px';panel.style.left=(state.l+(state.w-nw))+'px'}if(state.dir.includes('n')){const nh=Math.max(140,state.h-dy);panel.style.height=nh+'px';panel.style.top=(state.t+(state.h-nh))+'px'}}};const up=()=>{state.r=false;state.d=false;title.style.cursor='grab'};document.addEventListener('mousemove',mv);document.addEventListener('mouseup',up);const obs=new ResizeObserver(()=>{const w=btnContainer.clientWidth;const h=btnContainer.clientHeight;const btnW=38;const btnH=34;const cols=Math.floor(w/btnW);const rows=Math.floor(h/btnH);const cap=Math.max(1,(cols*rows));while(btnContainer.firstChild){btnContainer.removeChild(btnContainer.firstChild)}const speeds=[1];for(let i=2;i<=16;i++)speeds.push(i);let show=speeds;if(cap<speeds.length){show=speeds.slice(0,cap-1);show.push('...')}show.forEach(s=>{const b=document.createElement('button');if(s==='...'){b.textContent='...';b.className='tiny-overflow'}else{b.textContent=s+'x';b.onclick=()=>setSpeed(s)}btnContainer.appendChild(b)})});obs.observe(btnContainer);function setSpeed(s){const v=document.querySelector('video');if(v){v.playbackRate=s;input.value=s}}setInterval(()=>{const v=document.querySelector('video');if(v&&Math.abs(v.playbackRate-Number(input.value))>0.1&&document.activeElement!==input){input.value=v.playbackRate}},1000)})();
